let x = 10;
print("initial x = " + x);
x += 5;
print("x += 5 => " + x);
x -= 3;
print("x -= 3 => " + x);
x *= 2;
print("x *= 2 => " + x);
x /= 4;
print("x /= 4 => " + x);
x %= 3;
print("x %= 3 => " + x);
let y = 100;
y += 50;
print("y += 50 => " + y);
y -= 25;
print("y -= 25 => " + y);
y *= 2;
print("y *= 2 => " + y);
y /= 10;
print("y /= 10 => " + y);
let a = 7;
a %= 4;
print("a %= 4 => " + a);
print("=== compound assignment tests done ===");
