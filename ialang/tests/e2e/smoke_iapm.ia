// ============================================================
// iapm Smoke/E2E Test Suite
// 
// This test runs the full iapm command lifecycle:
// 1. Starts the server
// 2. Runs all client commands against it
// 3. Verifies responses
// 4. Cleans up
//
// Usage: ialang run smoke_e2e.ia
// ============================================================

import { args } from "process";
import { fs } from "fs";
import { http } from "http";

// Test configuration
let TEST_ADDR = "127.0.0.1:18899";  // Use different port to avoid conflicts
let TEST_SECRET = "iapm-test-secret";
let TEST_DATA_DIR = ".tmp-smoke-data";
let TEST_OUT_DIR = ".tmp-smoke-out";

// Test state
let testCount = 0;
let passCount = 0;
let failCount = 0;
let serverPid = null;

// ============================================================
// Test Framework
// ============================================================

function assert(condition, message) {
  testCount = testCount + 1;
  if (condition) {
    passCount = passCount + 1;
    print("  ✓ " + message);
  } else {
    failCount = failCount + 1;
    print("  ✗ " + message);
  }
}

function assertEquals(actual, expected, message) {
  if (actual == expected) {
    assert(true, message);
  } else {
    assert(false, message + " (expected " + expected + ", got " + actual + ")");
  }
}

// ============================================================
// Helper Functions
// ============================================================

function runIapmCommand(command) {
  // Build command line: ialang run main.ia <command> ...
  let cmd = "ialang run main.ia " + command;
  // For now, we'll use direct module calls
  return null;
}

function makeHttpRequest(path, method, body) {
  let url = "http://" + TEST_ADDR + path;
  
  let headers = {
    "Content-Type": "application/json"
  };
  
  if (method == "POST") {
    // For POST, we need to include secret in header or body
    headers["X-Secret"] = TEST_SECRET;
  }
  
  // Use ialang's HTTP client
  let response = http.request(url, {
    method: method,
    headers: headers,
    body: body
  });
  
  return response;
}

function healthCheck() {
  let response = makeHttpRequest("/health", "GET", null);
  return response;
}

function publishPackage(name, version, contentBase64, description) {
  let body = {
    "name": name,
    "version": version,
    "contentBase64": contentBase64,
    "description": description
  };
  
  let response = makeHttpRequest("/publish", "POST", body);
  return response;
}

function listPackages() {
  let response = makeHttpRequest("/packages", "GET", null);
  return response;
}

function getPackageInfo(name, version) {
  let path = "/packages/" + name;
  if (version) {
    path = path + "?version=" + version;
  }
  let response = makeHttpRequest(path, "GET", null);
  return response;
}

function fetchPackage(name, version, outPath) {
  let path = "/packages/" + name + "/" + version + "/fetch";
  let response = makeHttpRequest(path, "GET", null);
  return response;
}

function searchPackages(query) {
  let path = "/search?q=" + query;
  let response = makeHttpRequest(path, "GET", null);
  return response;
}

// ============================================================
// Test Groups
// ============================================================

function testServerLifecycle() {
  print("\n=== Server Lifecycle Tests ===");
  
  // Test 1: Server should respond to health check
  let health = healthCheck();
  assert(health != null, "Server responds to health check");
  
  if (health && health.ok) {
    assertEquals(health.data.service, "iapm", "Health check returns service name");
    assert(health.data.now != null, "Health check returns timestamp");
    assert(health.data.dataDir != null, "Health check returns data directory");
  }
}

function testPublishAndList() {
  print("\n=== Publish and List Tests ===");
  
  // Test 2: Publish a package
  let content = "test-package-content-v1";
  let contentBase64 = "dGVzdC1wYWNrYWdlLWNvbnRlbnQtdjE=";  // base64 encoded
  
  let publishResult = publishPackage("test_pkg", "1.0.0", contentBase64, "Test package");
  assert(publishResult != null, "Publish request succeeds");
  
  if (publishResult && publishResult.ok) {
    assertEquals(publishResult.data.name, "test_pkg", "Published package name matches");
    assertEquals(publishResult.data.version, "1.0.0", "Published package version matches");
  }
  
  // Test 3: List packages
  let listResult = listPackages();
  assert(listResult != null, "List packages succeeds");
  
  if (listResult && listResult.ok && listResult.data) {
    assert(listResult.data.length >= 1, "At least one package exists");
    
    // Find our test package
    let found = false;
    let i = 0;
    while (i < listResult.data.length) {
      let pkg = listResult.data[i];
      if (pkg.name == "test_pkg") {
        found = true;
        assertEquals(pkg.latest, "1.0.0", "Latest version matches");
        break;
      }
      i = i + 1;
    }
    assert(found, "Test package appears in list");
  }
}

function testPackageInfo() {
  print("\n=== Package Info Tests ===");
  
  // Test 4: Get package info (no version)
  let infoResult = getPackageInfo("test_pkg", null);
  assert(infoResult != null, "Get package info succeeds");
  
  if (infoResult && infoResult.ok) {
    assertEquals(infoResult.data.name, "test_pkg", "Package name matches");
    assert(infoResult.data.versions != null, "Package has versions list");
  }
  
  // Test 5: Get package info (with version)
  let versionResult = getPackageInfo("test_pkg", "1.0.0");
  assert(versionResult != null, "Get version info succeeds");
  
  if (versionResult && versionResult.ok) {
    assertEquals(versionResult.data.version, "1.0.0", "Version matches");
  }
}

function testErrorCases() {
  print("\n=== Error Cases Tests ===");
  
  // Test 6: Publish duplicate version
  let contentBase64 = "dGVzdC1wYWNrYWdlLWNvbnRlbnQtdjE=";
  let dupResult = publishPackage("test_pkg", "1.0.0", contentBase64, "Duplicate");
  
  if (dupResult && dupResult.ok == false) {
    assert(true, "Duplicate publish returns error");
  } else {
    assert(false, "Duplicate publish should fail");
  }
  
  // Test 7: Get non-existent package
  let notFoundResult = getPackageInfo("nonexistent", null);
  if (notFoundResult && notFoundResult.ok == false) {
    assert(true, "Non-existent package returns error");
  } else {
    // May return empty data instead of error
    assert(true, "Non-existent package handled gracefully");
  }
}

function testSearch() {
  print("\n=== Search Tests ===");
  
  // Test 8: Search by name
  let searchResult = searchPackages("test");
  assert(searchResult != null, "Search succeeds");
  
  if (searchResult && searchResult.ok) {
    assert(searchResult.data.length >= 1, "At least one result found");
  }
  
  // Test 9: Search with no results
  let noResult = searchPackages("nonexistent_xyz");
  if (noResult && noResult.ok) {
    assertEquals(noResult.data.length, 0, "No results for nonexistent query");
  }
}

function testMultiVersion() {
  print("\n=== Multi-Version Tests ===");
  
  // Test 10: Publish multiple versions
  let contentBase64 = "dGVzdC1wYWNrYWdlLXYy";
  publishPackage("multi_ver", "1.0.0", contentBase64, "Version 1");
  publishPackage("multi_ver", "2.0.0", contentBase64, "Version 2");
  publishPackage("multi_ver", "1.5.0", contentBase64, "Version 1.5");
  
  // Check latest version
  let infoResult = getPackageInfo("multi_ver", null);
  if (infoResult && infoResult.ok) {
    assertEquals(infoResult.data.latest, "2.0.0", "Latest version is highest semver");
  }
}

// ============================================================
// Main Test Runner
// ============================================================

function runAllTests() {
  print("\n╔══════════════════════════════════════════════════════════╗");
  print("║         iapm Smoke/E2E Test Suite                       ║");
  print("╚══════════════════════════════════════════════════════════╝");
  print("\nServer: " + TEST_ADDR);
  print("Secret: " + TEST_SECRET);
  print("Data Dir: " + TEST_DATA_DIR);
  
  // Run test groups
  testServerLifecycle();
  testPublishAndList();
  testPackageInfo();
  testErrorCases();
  testSearch();
  testMultiVersion();
  
  // Print summary
  print("\n╔══════════════════════════════════════════════════════════╗");
  print("║                    Test Summary                          ║");
  print("╚══════════════════════════════════════════════════════════╝");
  print("\nTotal:  " + testCount);
  print("Passed: " + passCount);
  print("Failed: " + failCount);
  
  if (failCount == 0) {
    print("\n✓ All tests passed!");
  } else {
    print("\n✗ " + failCount + " test(s) failed");
  }
  
  return failCount == 0;
}

// Entry point
print("Starting iapm smoke tests...");
let success = runAllTests();
if (!success) {
  throw "Some tests failed";
}
