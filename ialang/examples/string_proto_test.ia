let s = "  Hello World  ";
print("trim => '" + s.trim() + "'");
let s2 = "hello-world";
print("split => " + s2.split("-"));
let s3 = "HELLO";
print("toLowerCase => " + s3.toLowerCase());
let s4 = "hello";
print("toUpperCase => " + s4.toUpperCase());
let s5 = "hello world";
print("startsWith('hel') => " + s5.startsWith("hel"));
print("endsWith('rld') => " + s5.endsWith("rld"));
print("contains('lo wo') => " + s5.contains("lo wo"));
print("indexOf('lo') => " + s5.indexOf("lo"));
let s6 = "hello";
print("repeat(3) => " + s6.repeat(3));
let s7 = "hello world";
print("replace('world', 'ia') => " + s7.replace("world", "ia"));
let s8 = "42";
print("parseInt => " + s8.parseInt());
let s9 = "3.14";
print("parseFloat => " + s9.parseFloat());
let s10 = "Hello";
print("charAt(1) => " + s10.charAt(1));
print("substring(1, 4) => " + s10.substring(1, 4));
print("slice(1, -1) => " + s10.slice(1, -1));
let s11 = "hi";
print("padStart(5, '*') => " + s11.padStart(5, "*"));
print("padEnd(5, '*') => " + s11.padEnd(5, "*"));
let s12 = "  test  ";
print("trimLeft() => '" + s12.trimLeft() + "'");
print("trimRight() => '" + s12.trimRight() + "'");
print("=== string prototype tests done ===");
