let arr = [3, 1, 4, 1, 5, 9, 2, 6];
print("arr = " + arr);
print("arr.sort() => " + arr.sort());
print("arr.reverse() => " + ([1, 2, 3]).reverse());
print("arr.includes(4) => " + arr.includes(4));
print("arr.includes(10) => " + arr.includes(10));
print("arr.join('-') => " + ([1, 2, 3]).join("-"));
print("arr.join() => " + ([1, 2, 3]).join());
print("arr.indexOf(1) => " + ([1, 2, 1, 2]).indexOf(1));
print("arr.lastIndexOf(1) => " + ([1, 2, 1, 2]).lastIndexOf(1));
print("[1,2,3,4,5].slice(1, 3) => " + ([1, 2, 3, 4, 5]).slice(1, 3));
print("[1,2,3,4,5].slice(-2) => " + ([1, 2, 3, 4, 5]).slice(-2));
print("[1, [2, [3]]].flat() => " + ([1, [2, [3]]]).flat());
print("[1, [2, 3], 4].flat(2) => " + ([1, [2, 3], 4]).flat(2));
print("[1,2,3].concat([4,5]) => " + ([1, 2, 3]).concat([4, 5]));
print("[1,2,3].push(4) => " + ([1, 2, 3]).push(4));
print("[1,2,3].pop() => " + ([1, 2, 3]).pop());
print("[1,2,3].unshift(0) => " + ([1, 2, 3]).unshift(0));
print("[1,2,3].shift() => " + ([1, 2, 3]).shift());
print("[1,2,3].at(0) => " + ([1, 2, 3]).at(0));
print("[1,2,3].at(-1) => " + ([1, 2, 3]).at(-1));
let myArr = [10, 20, 30];
print("myArr.length => " + myArr.length);
let filled = ([1, 2, 3]).fill(0);
print("[1,2,3].fill(0) => " + filled);
let shuffled = ([1, 2, 3, 4, 5]).shuffle();
print("shuffle => " + shuffled);
print("=== array prototype tests done ===");
