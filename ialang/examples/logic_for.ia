let total = 0;
for (let i = 0; i < 6; i = i + 1) {
  if (i == 2 || i == 4) {
    total = total + i;
  }
}
if (!total == 6 && true) {
  print("logic bad: " + total);
} else {
  print("logic ok: " + total);
}

function mark() {
  print("mark-called");
  return true;
}

let a = true || mark();
let b = false && mark();
print("short: " + a + "," + b);
