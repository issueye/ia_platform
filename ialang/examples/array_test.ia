import { concat, slice, sort, reverse, includes, join, indexOf, lastIndexOf, range, shuffle, flat, fill, length } from "array";

print("=== array module tests ===");
let arr = [1, 2, 3, 4, 5];
print("arr = " + arr);
print("sort([3,1,4,1,5]) => " + sort([3, 1, 4, 1, 5]));
print("reverse([1,2,3]) => " + reverse([1, 2, 3]));
print("includes([1,2,3], 2) => " + includes([1, 2, 3], 2));
print("includes([1,2,3], 5) => " + includes([1, 2, 3], 5));
print("join([1,2,3], '-') => " + join([1, 2, 3], "-"));
print("concat([1,2], [3,4]) => " + concat([1, 2], [3, 4]));
print("slice([1,2,3,4,5], 1, 3) => " + slice([1, 2, 3, 4, 5], 1, 3));
print("slice([1,2,3,4,5], -2) => " + slice([1, 2, 3, 4, 5], -2));
print("indexOf([1,2,3,2,1], 2) => " + indexOf([1, 2, 3, 2, 1], 2));
print("lastIndexOf([1,2,3,2,1], 2) => " + lastIndexOf([1, 2, 3, 2, 1], 2));
print("range(5) => " + range(5));
print("range(2, 6) => " + range(2, 6));
print("range(0, 10, 2) => " + range(0, 10, 2));
print("flat([1, [2, 3], [4]]) => " + flat([1, [2, 3], [4]]));
print("fill('x', 5) => " + fill("x", 5));
print("length([1,2,3]) => " + length([1, 2, 3]));
print("=== array tests done ===");
